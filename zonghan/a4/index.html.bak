<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Assignment 4 Part B</title>
<link rel="icon" type="image/x-icon" href="laptop.ico">
<link rel="stylesheet" href="styles.css" >
</head>
<body>

<h1> Question Quiz</h1>
<p>Click <a href="cookie.html" target="_blank">here</a> to be directed to Cookie Clicker Game.</p>


<!--Example 1-->
<h3>Radio Buttons</h3>
<form>
    <label>Which language uses &lt;!----&gt; to create a comment?</label><br>
    <input id="correctLang" type="radio" value="HTML" name="group">
    <label>HTML</label><br>
    <input type="radio" value="CSS" name="group">
    <label>CSS</label><br>
    <input type="radio" value="JavaScript" name="group">
    <label>JavaScript</label><br>
    <input type="button" value="Submit" onclick="checkLang();"><br> 
	<input type="reset"><br> 
</form>


<!--Example 2-->
<h3>Dropdown Menu</h3>
<form>
    <label>What does "HTML" stand for?</label>
    <select id="HTMLQuestion"><!--no input for dropdown-->
        <option value="Hyperlinks and Text Markup Language">Hyperlinks and Text Markup Language</option>
        <option value="Hyper Text Markup Language">Hyper Text Markup Language</option>
        <option value="Home Tool Markup Language">Home Tool Markup Langauge</option>
        <option value="Home to my land">Home to my land</option>
    </select>
    <br>
    <input type="button" value="OK" onclick="checkHTML();">
    <input type="reset"><br> 
</form>

<!---JavaScript-->
<script>
//Example 1
function checkLang() {
	var correctAnswer = document.getElementById("correctLang").checked;
	// alert(correctAnswer); true or false
	
	if (correctAnswer == true) {
		alert("You are correct!");
	}
	else {
		alert("Wrong!");
	}
	
}

// Example 2
function checkHTML() {
    var chosenAnswer = document.getElementById("HTML Question").value;
	
    if (chosenAnswer == "Hyper Text Markup Language") {
		alert("Correct Answer");
	}
	else {
		alert("Incorrect answer");
	}
	
	document.getElementById("HTML Question").innerHTML = 
        " " + chosenAnswer;

}
</script>
</body>
</html>




