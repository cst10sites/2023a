

body {
	background-color: black;
	background-image: url("10-basic-html-tags.png");
	background-repeat: no-repeat;
	background-size: 100%; 
	background-attachment: fixed;
	color: OrangeRed;
	font-family: Courier;
	margin: 100px 25px;
}

h1 {
	-webkit-text-stroke-width: 1px;
	-webkit-text-stroke-color: white;	
}

div {
	padding: 50px;
	background: rgba(100, 100, 100, 0.5);
	/* rgba(Red, Green, Blue, Alpha/Opacity) */
	color: White;
}

a	{
	color: blue;
}

a:hover {
	color: red;
}

table, th, td {
	border: 2px solid white;
}

table {
	border-collapse: collapse;
}

th, td {
	color: white;
	font-weight: normal;
	padding: 5px;
	text-align: center;
}

u {
	color: blue;
	
}
