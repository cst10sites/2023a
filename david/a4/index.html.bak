<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Assignment 4</title>
 <link rel="icon" type="image/x-icon" href="cake.png">

<style>
</style>
<link rel="stylesheet" href="style.css">
</head>
<body>
<h1>Cookie Clicker</h1>
<h2 id="clickDisplay"></h2>
<button style="color:black;" onclick="alert('Click the cake to gain clicks.');">How to play</button> 
<br>
<button onClick="updateCPS();"><img src="cake.png" alt="cake"></button>
<p>Time:</p><p id="timeDisplay"></p>
<p>CPS:</p><p id="cpsDisplay"></p>
<button style="font-size:50px; width:100%; font-family:Comic sans MS; height:100%" onClick="window.location.href=window.location.href">Click to Reset</button> 
<script>
var nClicks = 0;
var startTime = new Date();
function showTimeElapsed() {
    var currentTime = new Date();
    var timeElapsed = currentTime - startTime;
	document.getElementById('display').innerHTML = timeElapsed / 1000;
}
function updateCPS() {
	if (nClicks == 0) {
		//reset startTime
		//increase nClicks by 1
		nClicks = nClicks + 1;
		startTime = new Date();
	
	}
	else {
		//note: this part runs when nClicks > 1
		// 1. create variable currentTime
		// 2. create variable timeElapsed amd subtract start and current time
		// 3. calculate CPS = nClicks/timeElapsed
		//    BUT timeElapsed be measured in seconds (not miliseconds)
		// 4. display CPS using id
		var currentTime = new Date();
		var timeAfterClick = (currentTime - startTime) / 1000;
		document.getElementById('timeDisplay').innerHTML = timeAfterClick;
		document.getElementById('clickDisplay').innerHTML = nClicks;
		document.getElementById('cpsDisplay').innerHTML = nClicks / timeAfterClick;
		nClicks = nClicks + 1;

		// alert(timeAfterClick);
	}
}


</script>
</body>
</html>