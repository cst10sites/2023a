<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Body</title>
<style></style>
<link rel="stylesheet" href="style.css">
<link rel="icon" type="image/x-icon" href="favicon.ico">
<body>
<h1>HTML Guide</h1>
<h2>Common HTML Tags inside &ltbody&gt</h2>
<p>Click <a href="head.html">here</a> to go to head;.</p>
<table style="width:100%;">
	<tr><!--table rox-->
	<th style="width:40%;">Tag</th><!--table header-->
	<th	style="width:30%";>Definition</th>
	<th	style="width:30%";	>Examples</th>
	</tr>
	
	<tr>
	<td>&ltimg alt="" style="width:10%;" src="crest.png"&gt</td><!--table data-->
	<td>Add the image and change the image size</td>
	<td><img alt="" style="width:10%;" src="640px-Apple-logo.png"></td>
	</tr>
	
	<tr>
	<td>&ltli&gt</td><!--table data-->
	<td>Make black dot infront of the text </td>
	<td>
	<li>Sleep</li>
	<li>Eat</li>
	<li>school</li>
	</td>
	</tr>
	
	<tr>
	<td>&ltp&gt</td><!--table data-->
	<td>Sentence</td>
	<td><p>I like to eat apple</p></td>
	</tr>
	
	<tr>
	<td>&ltBr&gt</td><!--table data-->
	<td>Skip a line</td>
	<td>Hi...<br><br>bye...</td>
	</tr>
	
	
	<tr>
	<td>&ltstrong&gt</td><!--table data-->
	<td>Defines important text</td>
	<td><strong>Hi</strong></td>
	</tr>
	
	<tr>
	<td>&lth1&gt&lth2&gt&lth3&gt&lth4&gt</td><!--table data-->
	<td>Different size of words</td>
	<td><h1>Hi</h1><h2>Hi</h2><h3>Hi</h3><h4>Hi</h4></td>
	</tr>
	
	<tr>
	<td>&lta href="https://www.youtube.com/"&gt</td><!--table data-->
	<td>go to a link</td>
	<td><a href="https://www.youtube.com/">here</a></td>
	</tr>
	
	<tr>
	<td>&ltp&gt&lta href="https://www.apple.ca"&gt <br><br>&ltimg
	src="640px-Apple-logo.png" alt="640px-Apple-logo.png" width=10%&gt
	&lt/a&gt&lt/p&gt</td><!--table data-->
	<td>go to a link</td>
	<td><p><a href="https://www.apple.ca">
<img src="640px-Apple-logo.png" alt="apple logo" width=10%>
</a></p></td>
	</tr>
	
	<tr>
	<td>&ltsup&gt</td><!--table data-->
	<td>The Superscript</td>
	<td><p>Main<sup>sup</sup></p></td>
	</tr>

	<tr>
	<td>&ltb&gt</td><!--table data-->
	<td>Another way to make words bold</td>
	<td><b>Main</b></td>
	</tr>	
	
	<tr>
	<td>&ltem&gt</td><!--table data-->
	<td>Defines emphasized text</td>
	<td><em>Main</em></td>
	</tr>
		
</table>
</body>



</head>