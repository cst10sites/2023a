body {
		background-image: url("https://dynamic-media-cdn.tripadvisor.com/media/photo-o/17/01/00/2b/the-strip.jpg?w=1200&h=1200&s=1");
		color: white;
		font-family: Helvetica;
		margin: 100px 25px;
		background-size: 100%;
		background-attachment: fixed;
}

div {
    padding: 50px;
    background: rgba(0, 0, 80, 0.5);
    color: white;	
}

a {
	color: violet;
}

a:hover {
	color: white;
}

table, th, td {
	border: 2px solid white;
}

th, td {
	color: white;
}

table {
	border-collapse: collapse;
	width:100%;
}

th {
	width:34%;
}