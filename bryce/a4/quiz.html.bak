<script>
function checkValue() {
    var correct = document.getElementById("correct").checked;
    
    if (correct == true) {
        alert("👍");
    }
    else {
        alert("👎");
    }
    
}

function checkValue2() {
    var correct = document.getElementById("correct").checked;
    
    if (correct == true) {
        alert("👍");
    }
    else {
        alert("👎");
    }
    
}

function checkSumbissive() {
    var choice1 = document.getElementById("choice1").checked;
