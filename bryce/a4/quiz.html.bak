    var choice3 = document.getElementById("choice3").checked;
    var choice4 = document.getElementById("choice4").checked;
    
    if (choice2 == true && choice3 == true && choice4 == false) {
        alert("👍");
	}
	else {
		alert("👎");
    }   


}

function checkColor() {
    var chosenCar = document.getElementById("colorValue").value;

    document.getElementById("colorDisplay").innerHTML = 
